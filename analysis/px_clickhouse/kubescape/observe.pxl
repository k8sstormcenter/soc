
import px

df = px.DataFrame('kubescape_logs', clickhouse_dsn='otelcollector:otelcollectorpass@hyperdx-hdx-oss-v2-clickhouse.click.svc.cluster.local:9000/default', start_time='-2d')
df.alert = df.message
df.namespace = px.pluck(df.RuntimeK8sDetails, "podNamespace")
df.podName = px.pluck(df.RuntimeK8sDetails, "podName")
df.time_ = px.int64_to_time(df.event_time * 1000000000)
df = df[['time_', 'alert', 'namespace', 'podName']]
px.display(df)
